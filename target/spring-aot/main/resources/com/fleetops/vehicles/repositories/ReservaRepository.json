      "name": "existsByClaveIdempotencia",
      "signature": "public abstract boolean com.fleetops.vehicles.repositories.ReservaRepository.existsByClaveIdempotencia(java.lang.String)",
      "query": {
        "query": "SELECT r.idReserva FROM ReservaVehiculo r WHERE r.claveIdempotencia = :claveIdempotencia"
      }
    },
    {
      "name": "existsByVehiculo_IdVehiculoAndFechaInicioLessThanEqualAndFechaFinGreaterThanEqual",
      "signature": "public abstract boolean com.fleetops.vehicles.repositories.ReservaRepository.existsByVehiculo_IdVehiculoAndFechaInicioLessThanEqualAndFechaFinGreaterThanEqual(java.util.UUID,java.time.LocalDateTime,java.time.LocalDateTime)",
      "query": {
        "query": "SELECT r.idReserva FROM ReservaVehiculo r WHERE r.vehiculo.idVehiculo = :idVehiculo AND r.fechaInicio <= :fechaFin AND r.fechaFin >= :fechaInicio"
      }
    },
