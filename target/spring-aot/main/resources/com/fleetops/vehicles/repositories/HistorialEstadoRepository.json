    {
      "name": "findByVehiculo_IdVehiculoAndRegistradoEnBetween",
      "signature": "public abstract java.util.List<com.fleetops.vehicles.models.entities.HistorialEstadoVehiculo> com.fleetops.vehicles.repositories.HistorialEstadoRepository.findByVehiculo_IdVehiculoAndRegistradoEnBetween(java.util.UUID,java.time.LocalDateTime,java.time.LocalDateTime)",
      "query": {
        "query": "SELECT h FROM HistorialEstadoVehiculo h WHERE h.vehiculo.idVehiculo = :idVehiculo AND h.registradoEn BETWEEN :desde AND :hasta"
      }
    },
    {
      "name": "findByVehiculo_IdVehiculoOrderByRegistradoEnDesc",
      "signature": "public abstract java.util.List<com.fleetops.vehicles.models.entities.HistorialEstadoVehiculo> com.fleetops.vehicles.repositories.HistorialEstadoRepository.findByVehiculo_IdVehiculoOrderByRegistradoEnDesc(java.util.UUID)",
      "query": {
        "query": "SELECT h FROM HistorialEstadoVehiculo h WHERE h.vehiculo.idVehiculo = :idVehiculo ORDER BY h.registradoEn desc"
      }
