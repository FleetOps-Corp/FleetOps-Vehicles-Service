# =====================================================
# Microservicio de Vehículos - FleetOps
# Archivo de variables de entorno (ejemplo)
#
# INSTRUCCIONES:
# 1. Copia este archivo y renómbralo como ".env"
# 2. Completa los valores reales según tu entorno
# 3. NUNCA subas el archivo .env al repositorio (está en .gitignore)
# =====================================================

# =====================================================
# Puerto del microservicio
# =====================================================
SERVER_PORT=8081

# =====================================================
# Base de datos PostgreSQL
# =====================================================
DB_HOST=localhost
DB_PORT=5432
DB_NAME=fleetops_vehicles
DB_USERNAME=fleetops
DB_PASSWORD=fleetops123

# =====================================================
# JWT - Clave secreta (¡OBLIGATORIA!)
# Esta clave debe ser la misma que usa el microservicio de Seguridad
# Debe tener al menos 256 bits (32 caracteres o más)
# =====================================================
JWT_SECRET_KEY=cambia_esta_clave_por_una_muy_segura_y_larga_1234567890

# =====================================================
# Comunicación con otros microservicios
# =====================================================
MAINTENANCE_SERVICE_URL=http://localhost:8083

# =====================================================
# CORS - Orígenes permitidos
# =====================================================
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost:8080

# =====================================================
# Opciones de desarrollo
# =====================================================
SHOW_SQL=false